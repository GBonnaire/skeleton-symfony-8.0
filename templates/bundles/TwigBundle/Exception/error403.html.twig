{% extends 'bundles/TwigBundle/Exception/error.html.twig' %}

{% block error_icon %}
    <div class="text-8xl mb-6" style="color: var(--da-border-strong);">
        <i class="fa-solid fa-lock"></i>
    </div>
{% endblock %}

{% block error_title %}
    <h1 class="text-2xl font-bold text-gray-800 mb-3">Accès refusé</h1>
{% endblock %}

{% block error_message %}
    <p class="text-gray-500 mb-8">
        Vous n'avez pas l'autorisation d'accéder à cette page.<br>
        Veuillez vous connecter ou contacter le support si vous pensez qu'il s'agit d'une erreur.
    </p>
{% endblock %}
