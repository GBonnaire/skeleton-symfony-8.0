{% extends 'base.html.twig' %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('layout-main') }}
{% endblock %}
{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('layout-main') }}
{% endblock %}

{% block body %}
<div class="flex flex-col min-h-dvh">
    {% include 'partials/navbar.html.twig' %}

    <main id="main-content" class="flex-1 max-md:pb-[72px]">
        {% block main %}{% endblock %}
    </main>

    {% include 'partials/footer.html.twig' %}
</div>
{% endblock %}
