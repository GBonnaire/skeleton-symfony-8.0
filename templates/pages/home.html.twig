{% extends 'layouts/main.html.twig' %}

{% block title %}{{ configuration.app.name }} — {{ configuration.app.description }}{% endblock %}
{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('page-home') }}
{% endblock %}
{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('page-home') }}
{% endblock %}

{% block main %}
    <div class="min-h-screen bg-gradient-to-br from-blue-50 to-indigo-100 flex items-center justify-center">
        <div class="max-w-2xl mx-auto px-4 py-16 text-center">
            <div
                class="bg-white rounded-2xl shadow-2xl p-12 transform hover:scale-105 transition-transform duration-300">
                <div class="mb-6">
                    <i class="fas fa-rocket text-6xl text-indigo-600 animate-bounce"></i>
                </div>

                <h1 class="text-5xl font-bold text-gray-800 mb-4">
                    <i class="fas fa-check-circle text-green-500 mr-2"></i>
                    Welcome to {{ configuration.app.name }}
                </h1>

                <div class="flex gap-4 justify-center flex-wrap mb-8">
                    <div class="bg-indigo-50 rounded-lg p-4 flex-1 min-w-[120px]">
                        <i class="fas fa-code text-2xl text-indigo-600 mb-2"></i>
                        <p class="text-sm text-gray-700 font-medium">Tailwind CSS</p>
                    </div>
                    <div class="bg-purple-50 rounded-lg p-4 flex-1 min-w-[120px]">
                        <i class="fas fa-icons text-2xl text-purple-600 mb-2"></i>
                        <p class="text-sm text-gray-700 font-medium">Font Awesome</p>
                    </div>
                    <div class="bg-blue-50 rounded-lg p-4 flex-1 min-w-[120px]">
                        <i class="fab fa-symfony text-2xl text-blue-600 mb-2"></i>
                        <p class="text-sm text-gray-700 font-medium">Symfony 8.0</p>
                    </div>
                </div>

                <div class="bg-gray-50 rounded-lg p-6 border-l-4 border-indigo-600">
                    <p class="text-sm text-gray-700 font-mono mb-2">
                        <i class="fas fa-terminal text-indigo-600 mr-2"></i>
                        Docker command to initialize claude in claudeAI container:
                    </p>
                    <code class="block bg-gray-800 text-green-400 px-4 py-3 rounded text-left font-mono text-sm">
                        /init-skeleton
                    </code>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
