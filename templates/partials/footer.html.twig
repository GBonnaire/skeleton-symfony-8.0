{% extends "partials/base.html.twig" %}

{% block partial_content %}
<footer class="border-t border-ink-100 bg-white py-6" role="contentinfo">
    <div class="da-container flex items-center gap-8 flex-wrap">

        <p class="text-[13px] text-ink-400 w-full text-center pt-2 border-t border-ink-100 md:w-auto md:pt-0 md:border-t-0">
            &copy; {{ "now"|date("Y") }} {{ configuration.app.name }} &mdash; {{ configuration.app.description }}
        </p>

    </div>
</footer>

{# Toasters pour chaque message flash (error, notice, success) #}
{% set flash_toast_types = {'error': 'danger', 'notice': 'notice', 'success': 'success'} %}
{% for flash_type, toast_type in flash_toast_types %}
    {% for message in app.flashes(flash_type) %}
        <twig:Toast type="{{ toast_type }}" :message="message|transFlash" />
    {% endfor %}
{% endfor %}

{% endblock %}
